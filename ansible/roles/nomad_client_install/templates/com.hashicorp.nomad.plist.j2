<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{{ nomad_client_install_launchd_label }}</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{ nomad_client_install_install_dir }}/nomad</string>
        <string>agent</string>
        <string>-config</string>
        <string>{{ nomad_client_install_config_dir }}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/nomad/nomad.out.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/nomad/nomad.err.log</string>
</dict>
</plist>
