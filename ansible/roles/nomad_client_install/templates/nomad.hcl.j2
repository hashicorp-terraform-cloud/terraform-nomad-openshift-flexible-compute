datacenter = "{{ nomad_client_install_datacenter }}"
region     = "{{ nomad_client_install_region }}"
data_dir   = "{{ nomad_client_install_data_dir | replace('\\', '/') }}"
{% if (nomad_client_install_edition == 'enterprise') and (nomad_client_install_license | length > 0) %}
license_path = "{{ [nomad_client_install_config_dir, 'license.hclic'] | join('/') | replace('\\', '/') }}"
{% endif %}

client {
  enabled   = true
  state_dir = "{{ nomad_client_install_state_dir | replace('\\', '/') }}"
  alloc_dir = "{{ nomad_client_install_alloc_dir | replace('\\', '/') }}"
  alloc_mounts_dir = "{{ nomad_client_install_alloc_mounts_dir | replace('\\', '/') }}"
  servers   = ["{{ nomad_client_install_server_address }}:4647"]
}

{% if (nomad_client_install_enable_raw_exec | default(false) | bool) and (ansible_facts.get('os_family', '') == 'Windows') %}
plugin "raw_exec" {
  config {
    enabled = true
  }
}
{% endif %}
